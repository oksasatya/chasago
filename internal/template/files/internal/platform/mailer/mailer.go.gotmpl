package mailer

import "context"

// Message is the payload passed to Mailer.Send.
type Message struct {
	To       string
	Template string // "welcome", "reset_password", etc.
	Lang     string // "en", "id"; empty → default
	Data     map[string]any
}

// Mailer is the minimal email abstraction. Swap implementations for SES,
// SendGrid, etc. — default is SMTP.
type Mailer interface {
	Send(ctx context.Context, m Message) error
}
