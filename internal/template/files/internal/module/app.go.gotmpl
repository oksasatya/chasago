package module

import (
	"go.uber.org/fx"

	"{{ .ModulePath }}/internal/config"
)

// All aggregates every fx.Module for the application. Add new modules here as
// the project grows.
func All(cfg *config.Config) fx.Option {
	return fx.Options(
		fx.Supply(cfg),
		Logger,
		Database,
		Redis,
		Auth,
		Mailer,
		Repository,
		Service,
		Controller,
		HTTP,
	)
}
